---
import MainLayout from '../layouts/MainLayout.astro';

/** * 【HAIL 实验室主页 - 首页内容版】 */
const labName = "HAIL";
const email = "HEMING001@e.ntu.edu.sg"; 

// 自动适配 GitHub Pages 子路径
const heroBgImage = "https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2000";

const affiliation = "ASIAN COMMUNICATION RESEARCH CENTRE (ACRC) | NTU";
const fullLabName = "Human AI-Interaction Lab";
const slogan = "Advancing Psychologically Aligned and Ethically Designed AI Systems for a Trustworthy Future of Human-AI Interaction.";
---

<MainLayout title="Home">
  <style>
    /* --- 1. Hero 区域样式 (保持 PC 端效果) --- */
    .hero-wrapper { 
        padding-bottom: 20px; 
        background: #fff; 
        scroll-margin-top: 100px; 
    }
    .hero {
      position: relative;
      height: 85vh;
      width: 100%;
      background-color: #050505;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      color: white;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      z-index: 1;
      background-size: cover;
      background-position: center;
    }

    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(50px); }
        to { opacity: 1; transform: translateY(-20px); }
    }

    .hero-content { 
        position: relative; 
        z-index: 5; 
        width: 100%; 
        max-width: 1200px; 
        padding: 0 5%; 
        text-align: left;
        animation: fadeInUp 1.5s ease-out forwards;
    }

    .hero-affiliation { font-size: 1rem; font-weight: 700; margin-bottom: 1rem; letter-spacing: 0.05em; color: white; }
    .hero-title { font-size: 3.5rem; font-weight: 800; line-height: 1.0; margin-bottom: 0.5rem; max-width: 800px; }
    .hero-slogan { font-size: 1.1rem; color: #bbc5d0; font-weight: 400; line-height: 1.4; max-width: 900px; }

    .scroll-hint {
      position: absolute;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 3;
      text-decoration: none;
      color: rgba(255, 255, 255, 0.5);
      font-size: 1.2rem;
      transition: 0.3s;
    }
    .scroll-hint:hover { color: white; transform: translateX(-50%) translateY(5px); }

    /* --- 2. Research Focus 区域样式 --- */
    #content-section { scroll-margin-top: 80px; }
    #research-focus {
      max-width: 1050px;
      margin: 60px auto 60px; 
      padding: 0 5%;
      text-align: center;
    }
    .area-title { font-size: 1.9rem; font-weight: 800; margin-bottom: 60px; text-transform: uppercase; letter-spacing: 1.5px; }
    .research-flex { display: flex; flex-wrap: wrap; justify-content: center; gap: 15px; }
    .focus-card {
      flex: 0 1 calc(33.33% - 15px);
      min-width: 270px;
      background: linear-gradient(145deg, #ffffff, #f9fafb);
      padding: 35px 25px;
      border-radius: 12px;
      border: 1px solid #f1f5f9;
      box-shadow: 0 4px 15px rgba(0,0,0,0.02);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      text-align: left;
    }
    .focus-card:hover { transform: translateY(-8px); border-color: #ce1126; box-shadow: 0 15px 35px rgba(206, 17, 38, 0.08); }
    .focus-card h3 { font-size: 1rem; color: #0f172a; line-height: 1.4; font-weight: 700; }

    /* --- 3. Footer 联系区域 (仅包含按钮逻辑) --- */
    .contact-footer { padding: 40px 5%; text-align: center; background: #f8fafc; border-top: 1px solid #f1f5f9; }
    .footer-text { font-size: 0.85rem; color: #727c8a; margin-bottom: 10px; line-height: 1.3; }
    .copy-btn {
      margin-top: 12px; padding: 10px 32px; background: #1e293b; color: white;
      border-radius: 40px; font-size: 0.85rem; font-weight: 500; cursor: pointer; border: none; transition: 0.3s;
    }
    .copy-btn:hover { background: #ce1126; transform: scale(1.05); }

    /* --- 4. 手机端专项适配修复 --- */
    @media (max-width: 768px) {
      .hero { height: 70vh; min-height: 420px; }
      .hero-title { font-size: 9vw; }
      .hero-slogan { font-size: 3.5vw; line-height: 1.3; }
      .area-title { font-size: 6vw; margin-bottom: 8vw; }
      .focus-card {
        flex: 0 1 100%; 
        padding: 5vw 6vw; 
        min-height: 20vw; 
        display: flex;
        align-items: center; 
        border-radius: 10px;
      }
      .focus-card h3 { font-size: 4.5vw; }
    }
  </style>

  <div id="home" class="hero-wrapper">
    <header class="hero">
      <div class="hero-bg" style={`background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.8)), url(${heroBgImage});`}></div>
      <div class="hero-content">
        <p class="hero-affiliation">{affiliation}</p>
        <h1 class="hero-title">{fullLabName}</h1>
        <p class="hero-slogan">{slogan}</p>
      </div>
      <a href="#content-section" class="scroll-hint">↓</a>
    </header>
  </div>

  <div id="content-section">
    <main id="research-focus">
      <h2 class="area-title">Research Focus</h2>
      <div class="research-flex">
          <div class="focus-card"><h3>AI Agent Design & <br/>User Experience</h3></div>
          <div class="focus-card"><h3>AI-Enhanced <br/>Research Methods</h3></div>
          <div class="focus-card"><h3>Explainable AI & <br/>User Understanding</h3></div>
          <div class="focus-card"><h3>Immersive AI <br/>Experiences</h3></div>
          <div class="focus-card"><h3>AI Ethics, <br/>Philosophy & Policy</h3></div>
      </div>
    </main>

    <section class="contact-footer">
      <p class="footer-text">Thoughts? Ideas? Collaboration opportunities?</p>
      <p class="footer-text">Get in touch with us</p>
      <button class="copy-btn" id="copyEmail" data-email={email}>Email Us</button>
    </section>
  </div>

  <script is:inline>
    document.getElementById('copyEmail').addEventListener('click', function() {
      const email = this.getAttribute('data-email');
      navigator.clipboard.writeText(email).then(() => {
        const originalText = this.innerText;
        this.innerText = 'Copied!';
        this.style.background = '#ce1126';
        setTimeout(() => {
          this.innerText = 'Email Us';
          this.style.background = '#1e293b';
        }, 2000);
      });
    });
  </script>
</MainLayout>