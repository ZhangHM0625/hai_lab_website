---
// src/layouts/MainLayout.astro
const { title } = Astro.props;
const labName = "HAIL";
const school = "WKWSCI";
const logoImage = `${import.meta.env.BASE_URL}/ntu-logo.png`;
---

<html lang="zh-cn">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{title} | {labName}</title>
  <style is:global>
    /* 全局基础样式 */
    :root { --ntu-red: #ce1126; --text-dark: #0f172a; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; overflow-x: hidden; width: 100%; }

    /* 导航栏基础布局 */
    .navbar {
      display: flex; 
      justify-content: space-between; 
      align-items: center;
      padding: 1rem 5%; 
      background: white; 
      position: sticky; 
      top: 0; 
      z-index: 1000; 
      border-bottom: 1px solid #f1f5f9;
      width: 100%;
    }
    
    .logo-module { 
      display: flex; 
      align-items: center; 
      text-decoration: none; 
      color: inherit; 
      flex-shrink: 0; 
    }
    
    /* 大屏下的校徽样式（带分割线） */
    .university-logo { 
      height: 45px; 
      border-right: 1px solid #e2e8f0; 
      padding-right: 15px; 
      margin-right: 20px; 
    }

    /* 文字包装容器 */
    .logo-text-wrapper { 
      display: flex; 
      flex-direction: column; 
      line-height: 1.1; 
    }

    /* 导航链接 */
    .nav-links { 
      display: flex; 
      gap: 30px; 
      list-style: none; 
      flex-shrink: 0; 
    }
    .nav-links a { 
      text-decoration: none; 
      color: #475569; 
      font-weight: 500; 
      font-size: 0.9rem; 
      transition: 0.3s; 
      white-space: nowrap; 
    }
    .nav-links a:hover { color: var(--ntu-red); }

    /* --------------------------------------------------------- */
    /* 响应式调整 */
    /* --------------------------------------------------------- */

    /* 中等屏幕（平板等）：缩小间距，保持文字 */
    @media (max-width: 768px) {
      .navbar { padding: 0.8rem 3%; }
      .nav-links { gap: 12px; }
      .nav-links a { font-size: 0.8rem; }
      .university-logo { height: 35px; margin-right: 10px; padding-right: 10px; }
    }

    /* 窄屏极限模式 (< 480px)：去掉文字，仅保留校徽图标 */
    @media (max-width: 480px) {
      /* 1. 彻底移除 HAIL 和 WKWSCI 文字 */
      .logo-text-wrapper { 
        display: none !important; 
      }

      /* 2. 移除校徽右侧的分割线和间距，释放空间 */
      .university-logo { 
        border-right: none; 
        padding-right: 0; 
        margin-right: 5px; /* 只留极小间距 */
        height: 32px; 
      }

      /* 3. 调整链接间距和字号，确保它们在校徽右侧排成一行 */
      .nav-links { 
        gap: 8px; 
      }
      .nav-links a { 
        font-size: 0.75rem; 
        letter-spacing: -0.3px; 
      }
    }

    /* 针对超窄屏 (如 iPhone SE) 的最终补丁 */
    @media (max-width: 340px) {
      .nav-links { gap: 5px; }
      .nav-links a { font-size: 0.7rem; }
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <a href={`${import.meta.env.BASE_URL}/`} class="logo-module">
      <img src={logoImage} alt="NTU Logo" class="university-logo" />
      <div class="logo-text-wrapper">
        <span style="font-weight: 800; font-size: 1.4rem;">{labName}</span>
        <span style="font-size: 0.8rem; color: #727c8a; font-weight: 600;">{school}</span>
      </div>
    </a>
    <ul class="nav-links">
      <li><a href={`${import.meta.env.BASE_URL}/`}>Home</a></li>
      <li><a href={`${import.meta.env.BASE_URL}/#content-section`}>Research</a></li>
      <li><a href={`${import.meta.env.BASE_URL}/publications`}>Publications</a></li>
      <li><a href={`${import.meta.env.BASE_URL}/people`}>People</a></li>
    </ul>
  </nav>

  <main>
    <slot />
  </main>

  <footer style="padding: 40px; text-align: center; border-top: 1px solid #f1f5f9; background: #f8fafc;">
    <p style="font-size: 0.8rem; color: #94a3b8;">© 2026 Human AI-Interaction Lab. All Rights Reserved.</p>
  </footer>
</body>
</html>