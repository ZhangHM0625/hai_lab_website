---

<MainLayout title="Publications">
  <style>
    /* 新增：从左到右出场动画定义 */
    @keyframes slideInFromLeft {
      0% {
        opacity: 0;
        transform: translateX(-40px);
      }
      100% {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .pub-hero {
      position: relative;
      height: 20vh;
      min-height: 300px;
      display: flex;
      align-items: center;
      padding: 0 5%;
      color: white;
      background-color: #050505;
      overflow: hidden;
    }
    .pub-hero-bg {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      background-size: cover;
      background-position: center;
      opacity: 0.5;
      z-index: 1;
    }
    .pub-hero-content {
      position: relative;
      z-index: 2;
      max-width: 1000px;
      margin: 0 auto;
      width: 100%;
      /* 为 Hero 内容添加动画 */
      animation: slideInFromLeft 0.8s ease-out forwards;
    }
    .pub-hero-title { font-size: 2.8rem; font-weight: 700; margin-bottom: 0.1rem; letter-spacing: -0.5px; }
    .pub-hero-subtitle { font-size: 1.2rem; color: #cbd5e1; font-weight: 400; }

    .pub-container { max-width: 900px; margin: 60px auto; padding: 0 5%; }
    
    .year-section { margin-bottom: 60px; }
    .year-heading {
      font-size: 2rem;
      font-weight: 800;
      color: #003087; /* 调整为 NTU 官方蓝 */
      padding-bottom: 10px;
      border-bottom: 1px solid #e2e8f0;
      margin-bottom: 20px;
      /* 为每个年份标题及底线添加动画 */
      animation: slideInFromLeft 0.8s ease-out forwards;
    }

    .paper-item { margin-bottom: 35px; }
    
    .paper-title {
      font-size: 1.2rem;
      font-weight: 600;
      color: #0f172a;
      display: inline-block;
      margin-bottom: 10px;
      line-height: 1.5;
      text-decoration: none; /* 移除下划线 */
    }
    
    .paper-meta { 
      font-size: 1rem; 
      color: #475569; /* 颜色调灰 */
      margin-bottom: 10px; 
      line-height: 1.5; 
    }
    
    .paper-links { display: flex; gap: 15px; margin-bottom: 8px; }
    .btn-link { 
      font-size: 0.95rem; 
      font-weight: 700; 
      color: #1e293b; 
      text-decoration: none; 
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      font-family: inherit;
    }
    .btn-link:hover { color: #ce1126; }

    .abstract-content {
      display: none;
      font-size: 0.95rem;
      line-height: 1.6;
      color: #334155;
      background: #f8fafc;
      padding: 15px 20px;
      border-left: 2px solid #94a3b8;
      margin-top: 8px;
    }

    @media (max-width: 768px) {
      .pub-hero { height: 15vh; min-height: 200px; }
      .pub-hero-title { font-size: 2.2rem; }
      .pub-container { margin: 40px auto; }
      .year-heading { font-size: 1.6rem; margin-bottom: 20px; }
      .paper-title { font-size: 1.05rem; }
      .paper-meta { font-size: 0.95rem; }
    }
  </style>

  <header class="pub-hero">
    <div class="pub-hero-bg" style={`background-image: url(${heroBgImage});`}></div>
    <div class="pub-hero-content">
      <h1 class="pub-hero-title">Publications</h1>
      <p class="pub-hero-subtitle">HAIL | Human + AI</p>
    </div>
  </header>

  <main class="pub-container">
   {publications.map((section: any) => (
      <div class="year-section">
        <h2 class="year-heading">{section.year}</h2>
        {section.papers.map((paper: any) => (
          <div class="paper-item">
            <span class="paper-title">{paper.title}</span>
            <p class="paper-meta">
              {paper.authors} ({section.year}). <span set:html={paper.journalInfo}></span>
            </p>
            
          <div class="paper-links">
              {paper.abstract && (
                <button class="btn-link abstract-btn" data-target={paper.id}>[Abstract]</button>
              )}
              {/* 兼容 doi 和 url 两种情况 */}
              {(paper.doi || paper.url) && (
                <a href={paper.doi ? `https://doi.org/${paper.doi}` : paper.url} target="_blank" rel="noopener noreferrer" class="btn-link">[Paper]</a>
              )}
            </div>
            
            {paper.abstract && (
              <div id={paper.id} class="abstract-content">
                <strong></strong> <span set:html={paper.abstract}></span>
              </div>
            )}
          </div>
        ))}
      </div>
    ))}
  </main>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.abstract-btn');
      buttons.forEach(button => {
        button.addEventListener('click', () => {
          const targetId = button.getAttribute('data-target');
          const abstractDiv = document.getElementById(targetId);
          
          if (abstractDiv.style.display === 'block') {
            abstractDiv.style.display = 'none';
          } else {
            abstractDiv.style.display = 'block';
          }
        });
      });
    });
  </script>
</MainLayout>