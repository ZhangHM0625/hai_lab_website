  },
  {
    id: "yanqin-wu",
    name: "Yanqin Wu",
    title: "Lab Member",
    image: `${import.meta.env.BASE_URL}/people/yanqin-wu.jpg`,
    website: "",
    scholar: "",
    bio: "Yanqin (Yasmin) is a PhD student at Wee Kim Wee School of Communication and Information at Nanyang Technological University (NTU). Her research interests include human-AI interaction, health communication (especially in mental health and stress management), and media effects. Her research explores how digital media and technology influence psychological responses and attitudinal/behavioral change."
  },
  {
    id: "heyongsun-im",
    name: "Heyongsun Im",
    title: "Lab Member",
    image: `${import.meta.env.BASE_URL}/people/heyongsun-im.jpg`,
    website: "",
    scholar: "",
    bio: "Hyeongsun is a PhD student at the Wee Kim Wee School of Communication and Information, Nanyang Technological University. His research interests are Human-Computer Interaction (HCI), Human-AI Interaction and social simulation."
  },
  {
    id: "keqi-chen",
    name: "Keqi Chen",
    title: "Lab Member",
    image: `${import.meta.env.BASE_URL}/people/keqi-chen.jpg`,
    website: "",
    scholar: "",
    bio: "Keqi Chen is a PhD student at School of Mechanical and Aerospace Engineering, Nanyang Technological University (NTU). He holds a Master’s degree in Design Informatics in University of Edinburgh (UoE). His research interests include Human Computer Interaction (HCI), Interaction Design (especially in Design of smart cockpit under autonomous driving), and User Experience. His research explores how to design the new human-vehicle interaction to cater to the new human-vehicle relationship under Autonomous Vehicle."
  },
  {
    id: "young-eun-kim",
    name: "Young Eun Kim",
    title: "Lab Member",
    image: `${import.meta.env.BASE_URL}/people/young-eun-kim.jpg`,
    website: "",
    scholar: "",
    bio: "Young Eun Kim is a PhD candidate in department of Interaction Science at Sungkyunkwan University, South Korea. Her research interests include Human-Computer Interaction, Human-AI Interaction, and User Experience. She has conducted research on improving employees' work experiences and adressing social issues (education, mental health, and older adults) from multiple interdisciplinary perspectives. She is currently a Visiting Student at Wee Kim Wee School of Communication and Information, Nanyang Technological University, for one year."
