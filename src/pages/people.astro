---
import MainLayout from '../layouts/MainLayout.astro';

// 背景图
const heroBgImage = `${import.meta.env.BASE_URL}/people-bg.png`;

// 实验室现任成员数据
const peopleData = [
  {
    id: "kwan-min-lee",
    name: "Professor Kwan Min Lee",
    title: "Korea Foundation Professor",
    image: `${import.meta.env.BASE_URL}/people/kwan-min-lee.jpg`,
    website: "https://kwanminlee.com/", 
    scholar: "",
    bio: "Professor Lee is a leading scholar in UX research, HCI, and digital culture. Formerly a VP at Samsung Electronics, he has published extensively, led $12M+ in funded research, and directs the Human AI-Interaction Lab (HAIL)."
  },
  {
    id: "kyung-won-cho",
    name: "Dr Kyung-Won Cho",
    title: "Lab Member",
    image: `${import.meta.env.BASE_URL}/people/kyung-won-cho.jpg`,
    website: "",
    scholar: "",
    bio: "Kyung-Won Cho received his Ph.D. in Computer Engineering from Honam University, Korea (2024), following an M.S. in Intelligent Robotics at GIST (2021) and a B.S. in Software Development at the University of Newcastle, Australia (2017). His research spans computer vision for aquaculture/medical imaging, texture-aware segmentation, and Generative AI for education. He is currently a Visiting Scholar at Nanyang Technological University (Wee Kim Wee School of Communication and Information)."
  },
