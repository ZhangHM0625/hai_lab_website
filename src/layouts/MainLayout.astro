---
const { title } = Astro.props;
const labName = "HAIL";
const school = "WKWSCI";
const logoImage = `${import.meta.env.BASE_URL}/ntu-logo.png`;
---

<html lang="zh-cn">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{title} | {labName}</title>
  <style is:global>
    :root { --ntu-red: #ce1126; --text-dark: #0f172a; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; overflow-x: hidden; width: 100%; }

    /* ── 导航栏基础 ── */
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 5%;
      background: white;
      position: sticky;
      top: 0;
      z-index: 1000;
      border-bottom: 1px solid #f1f5f9;
      width: 100%;
    }

    .logo-module {
      display: flex;
      align-items: center;
      text-decoration: none;
      color: inherit;
      flex-shrink: 0;
    }

    .university-logo {
      height: 45px;
      border-right: 1px solid #e2e8f0;
      padding-right: 15px;
      margin-right: 20px;
    }

    .logo-text-wrapper {
      display: flex;
      flex-direction: column;
      line-height: 1.1;
    }

    /* ── 导航链接 ── */
    .nav-links {
      display: flex;
      gap: 30px;
      list-style: none;
      flex-shrink: 0;
      align-items: center;
    }
    .nav-links > li > a {
      text-decoration: none;
      color: #475569;
      font-weight: 500;
      font-size: 0.9rem;
      transition: color 0.2s;
      white-space: nowrap;
    }
    .nav-links > li > a:hover { color: var(--ntu-red); }

    /* ── 下拉菜单 ── */
    .nav-dropdown { position: relative; }

    .dropdown-trigger {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .nav-arrow {
      display: inline-block;
      font-size: 0.7rem;
      transition: transform 0.25s ease;
      line-height: 1;
      transform: rotate(90deg);
    }
    .nav-dropdown:hover .nav-arrow { transform: rotate(0deg); }
    .nav-dropdown:hover > a { color: var(--ntu-red); }

    .dropdown-menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      padding-top: 14px;
      background: transparent;
      list-style: none;
      min-width: 148px;
      z-index: 999;
    }

    .dropdown-menu-inner {
      background: white;
      border: 1px solid #f1f5f9;
      border-radius: 10px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
      overflow: hidden;
    }

    .nav-dropdown:hover .dropdown-menu { display: block; }

    .dropdown-menu li a {
      display: block;
      padding: 11px 20px;
      font-size: 0.85rem;
      color: #475569;
      white-space: nowrap;
      border-bottom: 1px solid #f1f5f9;
      font-weight: 500;
      transition: color 0.2s;
      text-decoration: none;
    }
    .dropdown-menu li:last-child a { border-bottom: none; }
    .dropdown-menu li a:hover { color: var(--ntu-red); background: none; }

    /* ── 响应式 ── */
    @media (max-width: 768px) {
      .navbar { padding: 0.8rem 3%; }
      .nav-links { gap: 12px; }
      .nav-links > li > a { font-size: 0.8rem; }
      .university-logo { height: 35px; margin-right: 10px; padding-right: 10px; }
    }

    @media (max-width: 480px) {
      .logo-text-wrapper { display: none !important; }
      .university-logo {
        border-right: none;
        padding-right: 0;
        margin-right: 5px;
        height: 32px;
      }
      .nav-links { gap: 8px; }
      .nav-links > li > a { font-size: 0.75rem; letter-spacing: -0.3px; }
    }

    @media (max-width: 340px) {
      .nav-links { gap: 5px; }
      .nav-links > li > a { font-size: 0.7rem; }
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <a href={`${import.meta.env.BASE_URL}/`} class="logo-module">
      <img src={logoImage} alt="NTU Logo" class="university-logo" />
      <div class="logo-text-wrapper">
        <span style="font-weight: 800; font-size: 1.4rem;">{labName}</span>
        <span style="font-size: 0.8rem; color: #727c8a; font-weight: 600;">{school}</span>
      </div>
    </a>

    <ul class="nav-links">
      <li><a href={`${import.meta.env.BASE_URL}/`}>Home</a></li>

      <li class="nav-dropdown">
        <a href={`${import.meta.env.BASE_URL}/about`} class="dropdown-trigger">
          About Us <span class="nav-arrow">▾</span>
        </a>
        <ul class="dropdown-menu">
          <div class="dropdown-menu-inner">
            <li><a href={`${import.meta.env.BASE_URL}/about`}>Our Lab</a></li>
            <li><a href={`${import.meta.env.BASE_URL}/about#projects`}>Projects</a></li>
            <li><a href={`${import.meta.env.BASE_URL}/about#join-us`}>Join Us</a></li>
          </div>
        </ul>
      </li>

      <li><a href={`${import.meta.env.BASE_URL}/people`}>People</a></li>
      <li><a href={`${import.meta.env.BASE_URL}/publications`}>Publications</a></li>
    </ul>
  </nav>

  <main>
    <slot />
  </main>

  <footer style="padding: 40px; text-align: center; border-top: 1px solid #f1f5f9; background: #f8fafc;">
    <p style="font-size: 0.8rem; color: #94a3b8;">© 2026 Human AI-Interaction Lab. All Rights Reserved.</p>
  </footer>
</body>
</html>