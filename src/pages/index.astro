---
import MainLayout from '../layouts/MainLayout.astro';

const heroBgImage = `${import.meta.env.BASE_URL}/home-hero.png`;
const affiliation  = "Nanyang Technological University | WKWSCI";
const fullLabName  = "Human AI-Interaction Lab";
const slogan       = "Advancing Psychologically Aligned and Ethically Designed AI Systems for a Trustworthy Future of Human-AI Interaction.";
---

<MainLayout title="Home">
  <style>
    /* --- Hero --- */
    .hero {
      position: relative; height: 85vh; width: 100%;
      background-color: #050505; display: flex;
      align-items: center; justify-content: center;
      color: white; overflow: hidden;
    }
    .hero-bg {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      z-index: 1; background-size: cover; background-position: center;
    }
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(50px); }
      to   { opacity: 1; transform: translateY(-20px); }
    }
    .hero-content {
      position: relative; z-index: 5; width: 100%;
      max-width: 900px; padding: 0 5%; text-align: center;
      animation: fadeInUp 1.5s ease-out forwards;
    }
    .hero-affiliation {
      font-size: 0.9rem; font-weight: 600; margin-bottom: 1rem;
      letter-spacing: 0.08em; color: rgba(255,255,255,0.85);
      text-shadow: 0 1px 6px rgba(0,0,0,0.5);
    }
    .hero-title {
      font-size: 3.5rem; font-weight: 800; line-height: 1.1;
      margin-bottom: 0.8rem; text-shadow: 0 2px 12px rgba(0,0,0,0.5);
    }
    .hero-slogan {
      font-size: 1rem; color: rgba(255,255,255,0.88);
      line-height: 1.6; max-width: 700px; margin: 0 auto;
      text-shadow: 0 1px 6px rgba(0,0,0,0.5);
    }
    .scroll-hint {
      position: absolute; bottom: 30px; left: 50%;
      transform: translateX(-50%); z-index: 3;
      text-decoration: none; color: rgba(255,255,255,0.5);
      font-size: 1.2rem; transition: 0.3s;
    }
    .scroll-hint:hover { color: white; transform: translateX(-50%) translateY(5px); }

    /* --- Research Focus --- */
    #content-section { scroll-margin-top: 80px; }
    #research-focus {
      max-width: 1050px; margin: 0 auto;
      padding: 70px 5%; text-align: center;
    }
    .area-title {
      font-size: 1.9rem; font-weight: 800; margin-bottom: 16px;
      text-transform: uppercase; letter-spacing: 1.5px; color: #0f172a;
    }
    .title-divider {
      width: 48px; height: 3px; background: #ce1126;
      border-radius: 2px; margin: 0 auto 50px;
    }
    .research-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 24px; align-items: start;
    }
    .research-card {
      background: white; border: 1px solid #e8ecf0;
      border-radius: 14px; padding: 28px 24px;
      text-align: left; cursor: pointer; align-self: start;
      min-height: 120px; display: flex; flex-direction: column;
      justify-content: center;
      transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .research-card.dashed { border-style: dashed; cursor: default; }
    .research-card.dashed:hover { transform: none; box-shadow: none; border-color: #ce1126; }
    .research-card:not(.dashed):hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.07);
      border-color: #ce1126;
    }
    .card-title {
      font-size: 1rem; font-weight: 700;
      color: #0f172a; line-height: 1.4; margin: 0;
    }
    .card-desc {
      display: none; font-size: 0.85rem; color: #64748b;
      line-height: 1.75; margin: 0.8rem 0 0;
      padding-top: 0.8rem; border-top: 1px solid #e8ecf0;
    }
    .research-card.open .card-desc { display: block; }

    /* --- Contact Footer --- */
    .contact-footer {
      background: #f8fafc; border-top: 1px solid #f1f5f9;
      padding: 60px 5%; text-align: center;
    }
    .footer-tagline {
      font-size: 0.95rem; font-weight: 400;
      color: #475569; line-height: 1.8; margin: 0;
    }
    .footer-email-line {
      font-size: 0.95rem; color: #475569; margin-top: 0.8rem;
    }
    .footer-email { color: #ce1126; text-decoration: none; }
    .footer-email:hover { text-decoration: underline; }

    /* --- 响应式 --- */
    @media (max-width: 900px) {
      .research-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (min-width: 769px) and (max-width: 1100px) {
      .hero-bg { background-position: 60% center; }
    }
    @media (max-width: 768px) {
      .hero { height: 70vh; min-height: 420px; }
      .hero-title { font-size: 9vw; }
      .hero-slogan { font-size: 3.8vw; line-height: 1.5; }
      .hero-bg { background-position: 85% center; filter: brightness(0.75); }
      .area-title { font-size: 1.3rem; letter-spacing: 1px; }
      #research-focus { padding: 50px 5%; }
    }
    @media (max-width: 560px) {
      .research-grid { grid-template-columns: 1fr; }
    }
  </style>

  <!-- Hero -->
  <header class="hero">
    <div class="hero-bg" style={`background-image: linear-gradient(rgba(0,10,40,0.46), rgba(0,10,40,0.46)), url(${heroBgImage});`}></div>
    <div class="hero-content">
      <p class="hero-affiliation">{affiliation}</p>
      <h1 class="hero-title">{fullLabName}</h1>
      <p class="hero-slogan">{slogan}</p>
    </div>
    <a href="#content-section" class="scroll-hint">↓</a>
  </header>

  <!-- Research Focus -->
  <div id="content-section">
    <main id="research-focus">
      <h2 class="area-title">Research Focus</h2>
      <div class="title-divider"></div>

      <div class="research-grid">

        <div class="research-card">
          <div class="card-title">AI Agent Design &<br/>User Experience</div>
          <p class="card-desc">Investigating how AI system design shapes user experiences across diverse applications — from virtual influencers and robo-advisors to conversational assistants and autonomous vehicle interfaces.</p>
        </div>

        <div class="research-card">
          <div class="card-title">AI-Enhanced Research Methods</div>
          <p class="card-desc">Developing innovative methodologies that leverage AI as a research collaborator, including synthetic panels and artificial societies simulating diverse human populations to pre-test hypotheses and validate findings at scale.</p>
        </div>

        <div class="research-card">
          <div class="card-title">Explainable AI &<br/>User Understanding</div>
          <p class="card-desc">Developing frameworks for transparent AI systems that users can understand and collaborate with, particularly in high-stakes decision-making contexts where both trust and accurate comprehension of AI reasoning are critical.</p>
        </div>

        <div class="research-card">
          <div class="card-title">Immersive AI Experiences</div>
          <p class="card-desc">Exploring social presence and psychological responses in VR/AR environments and metaverse platforms where users interact with AI-driven agents — examining how immersive media shapes perception, behavior, and human-AI relationships.</p>
        </div>

        <div class="research-card">
          <div class="card-title">AI Ethics, Philosophy & Policy</div>
          <p class="card-desc">Examining the ethical implications of human-AI interaction — including agency, responsibility, and digital personhood — developing guidelines for responsible AI design and contributing to policy discussions on AI governance and regulation.</p>
        </div>

        <div class="research-card dashed">
          <div class="card-title">More Areas to Explore</div>
        </div>

      </div>
    </main>

    <!-- Contact -->
    <section class="contact-footer">
      <p class="footer-tagline">
        Thoughts? Ideas? Collaborations?<br/>
        Get in touch with us
      </p>
      <p class="footer-email-line">
        Email: <a href="mailto:kwanminlee@ntu.edu.sg" class="footer-email">kwanminlee@ntu.edu.sg</a>
      </p>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.research-card:not(.dashed)').forEach(card => {
        card.addEventListener('click', () => card.classList.toggle('open'));
      });
    });
  </script>
</MainLayout>