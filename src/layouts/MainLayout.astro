---
const { title } = Astro.props;
const logoImage = `${import.meta.env.BASE_URL}/ntu-logo.png`;
const hailLogo  = `${import.meta.env.BASE_URL}/hail-logo.png`;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{title} | HAIL</title>
  <style is:global>
    :root { --red: #ce1126; --dark: #0f172a; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; overflow-x: hidden; }

    /* ── 导航栏 ── */
    .navbar {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.8rem 5%; background: white; position: sticky;
      top: 0; z-index: 1000; border-bottom: 1px solid #f1f5f9;
    }
    .logo-module {
      display: flex; align-items: center;
      text-decoration: none; color: inherit; flex-shrink: 0;
    }
    .university-logo {
      height: 40px; border-right: 1px solid #e2e8f0;
      padding-right: 12px; margin-right: 14px;
    }
    .hail-logo { height: 46px; width: auto; object-fit: contain; }

    /* ── 桌面导航链接 ── */
    .nav-links {
      display: flex; gap: 28px; list-style: none; align-items: center;
    }
    .nav-links > li > a {
      text-decoration: none; color: #475569; font-weight: 500;
      font-size: 0.9rem; white-space: nowrap; transition: color 0.2s;
    }
    .nav-links > li > a:hover { color: var(--red); }

    /* ── 桌面下拉菜单 ── */
    .nav-dropdown { position: relative; }
    .dropdown-trigger { display: flex; align-items: center; gap: 4px; }
    .nav-arrow {
      font-size: 0.7rem; display: inline-block;
      transform: rotate(-90deg); transition: transform 0.25s ease;
    }
    .nav-dropdown:hover .nav-arrow { transform: rotate(0deg); }
    .nav-dropdown:hover > a { color: var(--red); }
    .dropdown-menu {
      display: none; position: absolute; top: 100%; left: 50%;
      transform: translateX(-50%); padding-top: 14px;
      list-style: none; min-width: 148px; z-index: 999;
    }
    .dropdown-menu-inner {
      background: white; border: 1px solid #f1f5f9;
      border-radius: 10px; box-shadow: 0 8px 24px rgba(0,0,0,0.08); overflow: hidden;
    }
    .nav-dropdown:hover .dropdown-menu { display: block; }
    .dropdown-menu li a {
      display: block; padding: 11px 20px; font-size: 0.85rem;
      color: #475569; border-bottom: 1px solid #f1f5f9;
      font-weight: 500; text-decoration: none; transition: color 0.2s;
    }
    .dropdown-menu li:last-child a { border-bottom: none; }
    .dropdown-menu li a:hover { color: var(--red); }

    /* ── 汉堡按钮（仅移动端）── */
    .hamburger {
      display: none; flex-direction: column; justify-content: center;
      gap: 5px; width: 36px; height: 36px;
      background: none; border: none; cursor: pointer; flex-shrink: 0;
    }
    .hamburger span {
      display: block; width: 100%; height: 2px;
      background: var(--dark); border-radius: 2px;
      transition: all 0.3s ease; transform-origin: center;
    }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* ── 移动端 ── */
    @media (max-width: 768px) {
      .hamburger { display: flex; }
      .university-logo { height: 32px; padding-right: 10px; margin-right: 10px; }
      .hail-logo { height: 34px; }
      .nav-arrow { display: none !important; }
      .dropdown-menu { display: none !important; }

      .nav-links {
        display: none; position: absolute; top: 100%; left: 0;
        width: 100%; background: white; flex-direction: column;
        align-items: flex-start; gap: 0;
        border-top: 1px solid #f1f5f9;
        box-shadow: 0 8px 24px rgba(0,0,0,0.08);
        padding: 4px 0 12px;
      }
      .nav-links.open { display: flex; }
      .nav-links > li { width: 100%; }
      .nav-links > li > a {
        display: block; padding: 14px 5%; font-size: 0.95rem;
        border-bottom: 1px solid #f8fafc;
      }
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <a href={`${import.meta.env.BASE_URL}/`} class="logo-module">
      <img src={logoImage} alt="NTU Logo" class="university-logo" />
      <img src={hailLogo}  alt="HAIL Logo" class="hail-logo" />
    </a>

    <button class="hamburger" id="hamburger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>

    <ul class="nav-links" id="navLinks">
      <li><a href={`${import.meta.env.BASE_URL}/`}>Home</a></li>
      <li class="nav-dropdown">
        <a href={`${import.meta.env.BASE_URL}/about`} class="dropdown-trigger">
          About Us <span class="nav-arrow">▾</span>
        </a>
        <ul class="dropdown-menu">
          <div class="dropdown-menu-inner">
            <li><a href={`${import.meta.env.BASE_URL}/about`}>Our Lab</a></li>
            <li><a href={`${import.meta.env.BASE_URL}/about#projects`}>Our Projects</a></li>
            <li><a href={`${import.meta.env.BASE_URL}/about#join-us`}>Join Us</a></li>
          </div>
        </ul>
      </li>
      <li><a href={`${import.meta.env.BASE_URL}/people`}>People</a></li>
      <li><a href={`${import.meta.env.BASE_URL}/publications`}>Publications</a></li>
    </ul>
  </nav>

  <main><slot /></main>

  <footer style="padding: 40px; text-align: center; border-top: 1px solid #f1f5f9; background: #f8fafc;">
    <p style="font-size: 0.8rem; color: #94a3b8;">© 2026 Human AI-Interaction Lab. All Rights Reserved.</p>
  </footer>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const hamburger = document.getElementById('hamburger');
      const navLinks  = document.getElementById('navLinks');

      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('open');
        navLinks.classList.toggle('open');
      });

      document.addEventListener('click', (e) => {
        if (!hamburger.contains(e.target) && !navLinks.contains(e.target)) {
          hamburger.classList.remove('open');
          navLinks.classList.remove('open');
        }
      });
    });
  </script>
</body>
</html>